{
  "schema_version": "1.0.0",
  "description": "Interface sketch for context decision layer output. This is a design artifact, not production code.",
  "sprint_id": "MAC/WIN-ROUTER-CONTEXT-RUNTIME-DESIGN-1",
  "status": "advisory — design only",
  "interfaces": {
    "context_decision_output": {
      "description": "Output from the context decision layer (advisory only)",
      "fields": {
        "decision_id": {
          "type": "string",
          "description": "Unique identifier for this decision"
        },
        "timestamp": {
          "type": "string",
          "format": "iso8601",
          "description": "Timestamp of decision generation"
        },
        "advisory_status": {
          "type": "string",
          "enum": ["non-production", "advisory", "production"],
          "description": "Authority level of this decision"
        },
        "workload_type": {
          "type": "string",
          "description": "Workload type that was evaluated"
        },
        "context_route": {
          "type": "object",
          "description": "Selected context route advisory",
          "fields": {
            "selected_route": {
              "type": "string",
              "enum": [
                "ram_cache",
                "ssd_cache",
                "remote_windows_runtime_cache",
                "recomputation_from_source",
                "compressed_recall_packet",
                "canonical_evidence_read",
                "hybrid_recall_plus_fresh_evidence",
                "recent_turn_window"
              ],
              "description": "Recommended context route"
            },
            "estimated_latency_ms": {
              "type": "number",
              "description": "Estimated latency based on measured costs"
            },
            "all_route_latencies": {
              "type": "object",
              "description": "Latency estimates for all evaluated routes"
            },
            "freshness_state": {
              "type": "string",
              "enum": [
                "verified_current",
                "recent_but_unverified",
                "stale_low_risk",
                "stale_requires_revalidation",
                "provenance_weak",
                "blocked_for_task"
              ],
              "description": "Freshness state of selected route"
            },
            "provenance_state": {
              "type": "string",
              "enum": ["verified", "partially_verified", "weak", "unknown", "blocked"],
              "description": "Provenance state of selected route"
            },
            "governance_outcome": {
              "type": "string",
              "enum": ["safe", "warning", "requires_revalidation", "blocked"],
              "description": "Governance evaluation result"
            },
            "performance_sacrificed_for_evidence": {
              "type": "boolean",
              "description": "Whether performance was sacrificed to meet evidence requirements"
            }
          }
        },
        "evidence_requirements": {
          "type": "object",
          "description": "Evidence requirements for this workload",
          "fields": {
            "requires_current_git_state": {
              "type": "boolean",
              "description": "Whether current git state is required"
            },
            "requires_current_test_state": {
              "type": "boolean",
              "description": "Whether current test output is required"
            },
            "requires_canonical_source": {
              "type": "boolean",
              "description": "Whether canonical source is required"
            },
            "allows_stale_context": {
              "type": "boolean",
              "description": "Whether stale context is acceptable"
            }
          }
        },
        "receipt_summary": {
          "type": "object",
          "description": "Human-readable summary for audit trail",
          "fields": {
            "label": {
              "type": "string",
              "description": "Short label for this decision"
            },
            "detail": {
              "type": "string",
              "description": "Detailed explanation of decision"
            },
            "risk": {
              "type": "string",
              "enum": ["low", "medium", "high"],
              "description": "Risk level of this decision"
            }
          }
        },
        "measured_costs_version": {
          "type": "string",
          "description": "Version of measured costs used for this decision"
        }
      },
      "example": {
        "decision_id": "ctx-decision-abc12345",
        "timestamp": "2026-06-28T12:00:00.000000+00:00",
        "advisory_status": "non-production",
        "workload_type": "sprint_closeout",
        "context_route": {
          "selected_route": "canonical_evidence_read",
          "estimated_latency_ms": 70.9,
          "all_route_latencies": {
            "canonical_evidence_read": 70.9,
            "compressed_recall_packet": 4.61,
            "ram_cache": 4.8,
            "ssd_cache": 18.2,
            "recomputation_from_source": 500.0
          },
          "freshness_state": "verified_current",
          "provenance_state": "verified",
          "governance_outcome": "safe",
          "performance_sacrificed_for_evidence": true
        },
        "evidence_requirements": {
          "requires_current_git_state": true,
          "requires_current_test_state": true,
          "requires_canonical_source": false,
          "allows_stale_context": false
        },
        "receipt_summary": {
          "label": "canonical_evidence_read selected for Sprint Closeout",
          "detail": "Performance was sacrificed to satisfy live_git_test_state evidence requirements.",
          "risk": "high"
        },
        "measured_costs_version": "1.0.0"
      }
    }
  }
}
